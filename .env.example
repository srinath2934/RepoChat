# Environment Variables Template
# Copy this file to .env and fill in your actual keys

# Groq API Key (Get from: https://console.groq.com/keys)
GROQ_API_KEY=your_groq_key_here

# Hugging Face Inference API Token (Get from: https://huggingface.co/settings/tokens)
# Required permissions: Read access + Inference Provider calls
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# GitHub Token (Optional - Recommended for higher rate limits)
GITHUB_TOKEN=your_github_token_here
